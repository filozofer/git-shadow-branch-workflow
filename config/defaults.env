# -------------------------------------------------------------------
# Workspace configuration
# -------------------------------------------------------------------
# Path to the directory containing your Git projects.
# If relative, it is resolved from the toolkit directory.
# Example: "../" means projects are next to the toolkit repo.
WORKSPACE_DIR="../"

# -------------------------------------------------------------------
# Branch configuration
# -------------------------------------------------------------------
# Main public branch used for integration.
PUBLIC_BASE_BRANCH="main"
# Suffix used for local shadow branches that keep private comments.
LOCAL_SUFFIX="@local"

# -------------------------------------------------------------------
# Local comments configuration
# -------------------------------------------------------------------
# Pattern used to detect local comments (default : one extra comment marker).
# Lines matching this pattern will be ignored for publication
# and rejected by the pre-commit hook if they are staged.
# Rule : single-line comment marker, with one additional marker (e.g. // -> ///, # -> ##).
# Note : markers must not conflict with standard syntax (e.g. ;; is valid bash, --- is valid YAML/Markdown).
LOCAL_COMMENT_PATTERN='^[[:space:]]*(///|##|%%|<!--)'

# Glob patterns for files to skip entirely during local comment stripping.
# Files matching any of these patterns are never inspected or modified,
# regardless of LOCAL_COMMENT_PATTERN.
# Space-separated; standard glob wildcards (* and ?) are supported.
LOCAL_COMMENT_EXCLUDE='*.md *.markdown *.json *.yaml *.yml *.toml *.lock'

# String prefix prepended to the commit message of shadow-only commits.
# Used by `git shadow commit` to label the local-comments commit.
SHADOW_COMMIT_PREFIX='[MEMORY]'

# Regex matched against commit message subjects to exclude commits from publication.
# Commits whose subject matches this pattern are skipped during `git shadow feature publish`.
# Must stay in sync with SHADOW_COMMIT_PREFIX.
SHADOW_COMMIT_FILTER='^\[MEMORY\]'

# -------------------------------------------------------------------
# Hook configuration
# -------------------------------------------------------------------
# Default hook location if the project does not define core.hooksPath.
DEFAULT_HOOK_PATH=".git/hooks/pre-commit"
# Marker line used to detect if hook content is already installed.
HOOK_CHECK_MARKER="# git-shadow pre-commit hook"

# -------------------------------------------------------------------
# Merge commit messages
# -------------------------------------------------------------------
# Message used when syncing public branch into local shadow branch.
SYNC_MERGE_MESSAGE_TEMPLATE="[SYNC] merge '%s' into '%s'"
# Message used when integrating a local feature branch into local base.
FEATURE_MERGE_MESSAGE_TEMPLATE="[FEATURE] merge '%s' into '%s'"

# -------------------------------------------------------------------
# Behavior flags
# -------------------------------------------------------------------
# Automatically pull base branches during finish-feature.
AUTO_PULL_BASE_BRANCHES="true"
# Allow deletion of feature branches after finish-feature.
DELETE_FEATURE_BRANCHES="true"
# Allow pushing shadow branches to a remote (bypasses the pre-push block).
# Set to "true" to permit pushing @local branches (e.g. for backup purposes).
# Can also be overridden at call time: GIT_SHADOW_ALLOW_LOCAL_PUSH=true git push
ALLOW_LOCAL_PUSH="false"
