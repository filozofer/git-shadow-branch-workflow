#!/usr/bin/env bash
set -euo pipefail

TOOL_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMMAND="${1:-}"
shift || true

# Main command dispatcher
case "$COMMAND" in
  new-feature)
    "$TOOL_ROOT/commands/new-feature.sh" "$@"
    ;;
  check-local-comments)
    "$TOOL_ROOT/commands/check-local-comments.sh" "$@"
    ;;
  commit)
    "$TOOL_ROOT/commands/commit.sh" "$@"
    ;;
  doctor)
    "$TOOL_ROOT/commands/doctor.sh" "$@"
    ;;
  publish)
    "$TOOL_ROOT/commands/publish.sh" "$@"
    ;;
  finish-feature)
    "$TOOL_ROOT/commands/finish-feature.sh" "$@"
    ;;
  install-hook)
    "$TOOL_ROOT/commands/install-hook.sh" "$@"
    ;;  help|-h|--help|"")
    cat <<EOF
git-shadow

Shadow branch pattern utilities.

Commands:
  install-hook
  doctor
  new-feature <branch>
  commit [-m "message"]
  publish [--commit] [-m MESSAGE]
  finish-feature

Examples:
  git shadow new-feature feature/login
  git shadow commit -m "feat(auth): login route"
  git shadow publish --commit -m "feat: login"
  git shadow finish-feature
EOF
    ;;
  *)
    echo "Unknown command: $COMMAND"
    exit 1
    ;;
esac