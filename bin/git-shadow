#!/usr/bin/env bash
set -euo pipefail

# Resolve TOOL_ROOT correctly even when this script is invoked via a symlink.
_gs_script="${BASH_SOURCE[0]}"
while [[ -L "$_gs_script" ]]; do
  _gs_dir="$(cd "$(dirname "$_gs_script")" && pwd)"
  _gs_target="$(readlink "$_gs_script")"
  if [[ "$_gs_target" == /* ]]; then
    _gs_script="$_gs_target"
  else
    _gs_script="$_gs_dir/$_gs_target"
  fi
done
TOOL_ROOT="$(cd "$(dirname "$_gs_script")/.." && pwd)"
unset _gs_script _gs_dir _gs_target
COMMAND="${1:-}"
shift || true

# --- Two-level dispatch: git shadow <group> <subcommand> ---
# If commands/<COMMAND>/ is a directory, treat the next arg as a subcommand.
if [[ -n "$COMMAND" && -d "$TOOL_ROOT/commands/$COMMAND" ]]; then
  SUBCOMMAND="${1:-}"
  if [[ -z "$SUBCOMMAND" ]]; then
    echo "❌ Missing subcommand for '$COMMAND'. Try: git shadow $COMMAND <subcommand>" >&2
    exit 1
  fi
  script="$TOOL_ROOT/commands/$COMMAND/$SUBCOMMAND.sh"
  if [[ -f "$script" ]]; then
    shift
    exec "$script" "$@"
  fi
  echo "❌ Unknown subcommand '$SUBCOMMAND' for '$COMMAND'." >&2
  echo "   Run 'git shadow help' for usage." >&2
  exit 1
fi

# --- One-level dispatch: git shadow <command> ---
if [[ -n "$COMMAND" && -f "$TOOL_ROOT/commands/$COMMAND.sh" ]]; then
  exec "$TOOL_ROOT/commands/$COMMAND.sh" "$@"
fi

case "$COMMAND" in
  --version|-V)
    exec "$TOOL_ROOT/commands/version.sh"
    ;;
  help|-h|--help|"")
    cat <<EOF
git-shadow

Shadow branch pattern utilities.

Commands:
  version
  install-hooks
  doctor
  status [--json]
  completion install
  feature start <branch>
  feature publish [--commit] [-m MESSAGE]
  feature finish [--keep-branches] [--no-pull] [--force]
  commit [-m "message"]
  check-local-comments
  config list [--json]
  config show [--json]
  config get <KEY> [--json]
  config set <KEY>=<VALUE>|<KEY> <VALUE> [--project-config|--user-config]
  config unset <KEY> [--project-config|--user-config]

Examples:
  git shadow feature start feature/login
  git shadow commit -m "feat(auth): login route"
  git shadow feature publish --commit -m "feat: login"
  git shadow feature finish
  git shadow config show
  git shadow config get LOCAL_SUFFIX
  git shadow config set LOCAL_SUFFIX=@mine --project-config
  git shadow config unset LOCAL_SUFFIX --project-config
EOF
    ;;
  *)
    echo "❌ Unknown command: $COMMAND" >&2
    echo "   Run 'git shadow help' for usage." >&2
    exit 1
    ;;
esac
