{
  "name": "git-shadow",
  "version": "1.0.4",
  "description": "Shadow branch pattern utilities for Git — keep local thinking artifacts without polluting the shared repository.",
  "homepage": "https://github.com/filozofer/git-shadow",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/filozofer/git-shadow.git"
  },
  "license": "MIT",
  "bin": {
    "git-shadow": "bin/git-shadow"
  },
  "files": [
    "bin/",
    "commands/",
    "config/",
    "lib/",
    "scripts/",
    "VERSION"
  ],
  "scripts": {
    "postinstall": "chmod +x bin/git-shadow && find . -name '*.sh' -exec chmod +x {} \\; 2>/dev/null || true"
  },
  "os": [
    "linux",
    "darwin"
  ],
  "engines": {
    "node": ">=14"
  },
  "keywords": [
    "git",
    "shadow",
    "branch",
    "workflow",
    "comments",
    "local"
  ]
}
